{
  "name": "@snazzieslab/artifactuploadcli",
  "version": "1.0.0",
  "description": "Share a file via a terminal QR code — upload to Cloudflare R2, or serve it over your local network. No R2 needed for LAN serving.",
  "type": "module",
  "bin": {
    "artifactuploadcli": "dist/index.js"
  },
  "files": [
    "dist",
    "llms.txt"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "cloudflare",
    "r2",
    "upload",
    "qrcode",
    "cli",
    "bun"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SnazziesLab/artifactuploadcli.git"
  },
  "homepage": "https://github.com/SnazziesLab/artifactuploadcli#readme",
  "scripts": {
    "check": "tsc --noEmit",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --target=node --outfile=dist/index.js",
    "prepublishOnly": "tsc --noEmit && bun run build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@aws-sdk/lib-storage": "^3.1073.0",
    "dotenv": "^16.6.1",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/qrcode-terminal": "^0.12.2",
    "bun-types": "latest",
    "typescript": "^6.0.3"
  }
}
