{
  "name": "artifactuploadcli",
  "version": "1.0.0",
  "description": "Upload files to Cloudflare R2 and display a QR code in the terminal",
  "type": "module",
  "bin": {
    "artifactuploadcli": "src/index.ts"
  },
  "files": [
    "src",
    "llms.txt"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "keywords": [
    "cloudflare",
    "r2",
    "upload",
    "qrcode",
    "cli",
    "bun"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Snazzie/artifactuploadcli.git"
  },
  "homepage": "https://github.com/Snazzie/artifactuploadcli#readme",
  "scripts": {
    "check": "tsc --noEmit",
    "start": "bun src/index.ts",
    "prepublishOnly": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@aws-sdk/lib-storage": "^3.1073.0",
    "dotenv": "^16.6.1",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/qrcode-terminal": "^0.12.2",
    "bun-types": "latest",
    "typescript": "^6.0.3"
  }
}
